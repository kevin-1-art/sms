# School Management System - Environment Configuration
# Copy this file to .env and update with your production values
# DO NOT commit .env to version control!

# ==============================================================================
# DJANGO CORE SETTINGS
# ==============================================================================

# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Set to False for production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,localhost

# ==============================================================================
# HTTPS/SSL SECURITY SETTINGS (CRITICAL!)
# ==============================================================================

# Force all HTTP traffic to HTTPS
SECURE_SSL_REDIRECT=True

# Make session cookies HTTPS-only (set to True in production)
SESSION_COOKIE_SECURE=True

# Make CSRF cookies HTTPS-only (set to True in production)
CSRF_COOKIE_SECURE=True

# HTTP Strict Transport Security (1 year in seconds)
SECURE_HSTS_SECONDS=31536000

# Include subdomains in HSTS
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

# Enable HSTS preload (add site to browser preload list)
SECURE_HSTS_PRELOAD=True

# Trusted origins for CSRF (behind reverse proxy)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==============================================================================
# DATABASE SETTINGS
# ==============================================================================

# For development (SQLite - default)
# DATABASE_URL=sqlite:///db.sqlite3

# For production (PostgreSQL - RECOMMENDED)
# Format: postgresql://user:password@localhost:5432/school_management
DATABASE_URL=postgresql://school_user:secure_password@db.example.com:5432/school_management

# Database engine choice
# Options: sqlite3 (dev), postgresql (production), mysql (not recommended)
DATABASE_ENGINE=postgresql

# ==============================================================================
# EMAIL CONFIGURATION (for password reset, notifications)
# ==============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-school-email@gmail.com
# Use app password, not regular Gmail password
EMAIL_HOST_PASSWORD=your-16-character-app-password

# Alternative: SendGrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key

# Default email sender
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ==============================================================================
# AWS S3 CONFIGURATION (for static files & media in production)
# ==============================================================================

# Use S3 for static and media files
USE_S3=False

# AWS credentials
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=school-management-bucket
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=school-management-bucket.s3.amazonaws.com

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=/var/log/school-management/app.log

# ==============================================================================
# SECURITY & SSL CERTIFICATES
# ==============================================================================

# Path to SSL certificate (Let's Encrypt)
SSL_CERTIFICATE_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem

# Path to SSL private key
SSL_PRIVATE_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ==============================================================================
# REDIS CONFIGURATION (for caching, sessions)
# ==============================================================================

REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# API & THIRD-PARTY INTEGRATIONS
# ==============================================================================

# Google OAuth (if implementing social login)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ==============================================================================
# MONITORING & LOGGING SERVICES
# ==============================================================================

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# New Relic (APM monitoring)
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# ==============================================================================
# ENVIRONMENT SPECIFIC SETTINGS
# ==============================================================================

# Environment: development, staging, production
ENVIRONMENT=production

# Time zone
TIME_ZONE=UTC

# Language
LANGUAGE_CODE=en-us

# ==============================================================================
# DEVELOPMENT ONLY SETTINGS (Comment out in production)
# ==============================================================================

# Allow requests from any origin (DEVELOPMENT ONLY!)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Insecure cookies (DEVELOPMENT ONLY!)
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False

# ==============================================================================
# INSTRUCTIONS FOR USE
# ==============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Update all values with your actual settings
# 3. Make .env non-readable by others: chmod 600 .env
# 4. Add .env to .gitignore (never commit!)
# 5. In settings.py: use os.environ.get('VARIABLE_NAME', 'default_value')
# 6. Load .env in your deployment:
#    - Docker: Use 'env_file: .env' in docker-compose.yml
#    - Heroku: Use 'heroku config:set KEY=VALUE'
#    - AWS: Use AWS Secrets Manager or Parameter Store
#    - Manual: 'export $(cat .env | xargs)' then 'gunicorn ...'
